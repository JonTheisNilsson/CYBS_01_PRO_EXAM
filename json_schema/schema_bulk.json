{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "@odata.context": {"type": "string"},
    "@odata.count": {"type": "number"},
    "api_version": {"type": "string"},
    "mode": {"type": "string"},
    "note": {"type": "string"},
    "pagination": {
      "type": "object",
      "properties": {
        "filtered_total": {"type": "number", "minimum": 0 },
        "returned": {"type": "number", "minimum": 0 },
        "skip": {"type": "number", "minimum": 0 },
        "top": {"type": "number", "minimum": 0, "maximum": 100 },
        "unfiltered_total": {"type": "number", "minimum": 0 }
      },
      "required": [
        "filtered_total",
        "returned",
        "skip",
        "top",
        "unfiltered_total"
      ]
    },
    "value": {
      "type": "array"
    }
  },
  "required": [
    "@odata.context",
    "@odata.count",
    "api_version",
    "mode",
    "note",
    "pagination",
    "value"
  ]
}