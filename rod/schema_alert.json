{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "alertId": { "type": "string" },
    "category": { "type": "string" },
    "computerDnsName": { "type": "string" },
    "detectionSource": { "type": "string" },
    "entities": {
      "type": "object",
      "properties": {
        "domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "emails": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fileHashes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ips": {
          "type": "array",
          "items": { "type": "string" }
        },
        "processes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "urls": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": [
        "domains",
        "emails",
        "fileHashes",
        "ips",
        "processes",
        "urls"
      ]
    },
    "firstActivity": { "type": "string" },
    "lastActivity": { "type": "string" },
    "machineId": { "type": "string" },
    "severity": { "type": "string" },
    "title": { "type": "string" }
  },
  "required": [
    "alertId",
    "category",
    "computerDnsName",
    "detectionSource",
    "entities",
    "firstActivity",
    "lastActivity",
    "machineId",
    "severity",
    "title"
  ]
}